# ============================================================
# PhishGuard – Environment variable reference
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored.

# ── Backend ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins for CORS.
# Default: localhost development ports.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend (set at BUILD time for Vite) ────────────────────
# Full URL of the backend API. Must be reachable from the
# browser (not from the server/container).
# In development with the Vite proxy this is not needed.
VITE_API_URL=http://localhost:8000
